#!/bin/sh

# Prevent committing dist paths from visualization-component in angular.json
if git diff --cached -- angular.json | grep -q '"\.\./visualization-component/dist/'; then
  echo ""
  echo "❌ Commit blocked: angular.json contains a reference to ../visualization-component/dist/"
  echo "   Remove the dist path from 'scripts' before committing."
  echo ""
  exit 1
fi

exit 0
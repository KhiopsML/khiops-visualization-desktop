{
  "name": "khiops-visualization-desktop",
  "title": "Khiops Visualization Desktop",
  "main": "app/main.js",
  "version": "11.7.2",
  "license": "BSD-3-Clause-Clear",
  "author": {
    "name": "Orange",
    "email": "khiops.team@orange.com"
  },
  "description": "Khiops Visualization Desktop application for Windows, Mac and Linux",
  "repository": {
    "type": "git",
    "url": "https://github.com/KhiopsML/khiops-visualization-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/KhiopsML/khiops-visualization-desktop/issues"
  },
  "homepage": "https://github.com/KhiopsML/khiops-visualization-desktop#readme",
  "browser": {
    "child_process": false,
    "crypto": false,
    "electron": false,
    "fs": false,
    "http": false,
    "https": false,
    "net": false,
    "os": false,
    "path": false,
    "stream": false,
    "tls": false
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "ng": "ng",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "e2e:ui": "playwright test -c e2e/playwright.config.ts  --ui",
    "e2e:watch": "concurrently --kill-others-on-fail \"yarn ng:serve:dev\" \"wait-on http://localhost:4200 && playwright test -c e2e/playwright.config.ts --ui --ui-host=localhost --ui-port=8080\"",
    "dev": "./scripts/build-dev-watch.sh",
    "buildNstart": "yarn build-visu && npm-run-all -p electron:serve ng:serve",
    "start": "npm-run-all -p electron:serve ng:serve:dev",
    "setTag": "./scripts/tag.sh",
    "ng:serve": "ng serve -o",
    "ng:serve:dev": "ng serve -o -c dev",
    "setEnv": "node ./scripts/set-env.js",
    "build-visu": "cd ../visualization-component && yarn install && yarn build:webcomponents",
    "build": "yarn electron:serve-tsc && ng build --base-href ./",
    "build:dev": "yarn build -c dev",
    "build:prod": "yarn build -c production && yarn removeMocks",
    "web:build": "yarn build -c web-production",
    "electron": "electron",
    "electron:serve-tsc": "tsc -p tsconfig.serve.json",
    "electron:serve": "wait-on tcp:4200 && yarn electron:serve-tsc && electron . --serve --no-sandbox",
    "electron:local": "yarn build:prod && electron .",
    "electron:build": "yarn build:prod && electron-builder build --publish=never",
    "publishReleases": "yarn build-visu && cd ../khiops-visualization-desktop && yarn build:prod && electron-builder build --windows --ia32 -p always && electron-builder build --linux -p always && electron-builder build --mac -p always",
    "removeDist": "rimraf dist && rimraf release && rimraf .cache",
    "removeMocks": "rimraf dist/khiops-visualization-desktop/mocks",
    "electron:linux": "yarn build:prod && electron-builder build --linux -p always",
    "electron:windows": "yarn build:prod && electron-builder build --windows --ia32 -p always",
    "electron:windows:local": "yarn build:prod && electron-builder build --windows --ia32",
    "electron:windows32": "yarn build:prod && electron-builder build --windows --ia32 -p always",
    "electron:windows64": "yarn build:prod && electron-builder build --windows --x64 -p always",
    "electron:publish": "yarn build:prod && electron-builder build --publish=never",
    "electron:mac": "yarn build:prod && electron-builder build --mac -p always",
    "lint": "ng lint",
    "addHeader": "ts-node scripts/add-header.js",
    "updateElectron": "npx cross-env ELECTRON_GET_USE_PROXY=true GLOBAL_AGENT_HTTPS_PROXY=http://proxypac.si.francetelecom.fr:8080/ yarn add electron@latest --force --legacy-peer-deps",
    "updateVersions": "ncu -u --target minor",
    "playwright:ui": "playwright test --ui",
    "playwright:debug": "playwright test --debug",
    "test": "ng test --watch=false",
    "test:watch": "ng test --watch=true"
  },
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/language-service": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@electron/remote": "^2.1.3",
    "@types/node": "^25.5.0",
    "JSONStream": "^1.3.5",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "electron-json-storage": "^4.6.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "event-stream": "^4.0.1",
    "khiops-visualization": "^11.14.0",
    "ngx-matomo-client": "^9.0.1",
    "postcss-loader": "^8.2.1",
    "rxjs": "^7.8.2",
    "toastify-js": "^1.12.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@electron/notarize": "^3.1.1",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@playwright/test": "1.58.2",
    "@types/jasmine": "^6.0.0",
    "@types/jasminewd2": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.2",
    "electron-builder-notarize": "^1.5.2",
    "electron-debug": "^4.1.0",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-reloader": "^1.2.3",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "jasmine-core": "^6.1.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-electron": "^7.3.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "wait-on": "9.0.4"
  },
  "browserslist": [
    "chrome 110"
  ]
}
